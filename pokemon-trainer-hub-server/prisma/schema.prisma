// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model DreamTeamMember {
  id          Int      @id @default(autoincrement())
  auth0UserId String
  pokemonId   Int
  pokemonName String
  spriteUrl   String
  addedAt     DateTime @default(now())
  // Drag-and-drop slot order within the team (0 = first slot). Not unique at
  // the DB level — the reorder endpoint is what guarantees each user's
  // members always hold distinct, contiguous values; this column is just
  // storage for whatever it last computed.
  position    Int      @default(0)

  @@unique([auth0UserId, pokemonId])
}

model Favorite {
  id          Int      @id @default(autoincrement())
  auth0UserId String
  pokemonId   Int
  pokemonName String
  spriteUrl   String
  addedAt     DateTime @default(now())

  @@unique([auth0UserId, pokemonId])
}

// A trainer's personal free-text notes about a specific Pokémon — works for
// ANY Pokémon opened in the Detail Modal, not just ones on the team/favorited.
// One Pokémon can have many notes (a running log), each individually
// deletable — no unique constraint, unlike Favorite/DreamTeamMember.
model TrainerNote {
  id          Int      @id @default(autoincrement())
  auth0UserId String
  pokemonId   Int
  text        String
  createdAt   DateTime @default(now())
}

// A trainer's Contact Support submission — a running log (multiple per
// user allowed, like TrainerNote), never edited after creation. There's no
// admin UI for this yet, so rows are only ever reviewed directly in the
// database — an honest, real (if minimal) alternative to faking a "request
// sent" success message with nothing behind it.
model SupportRequest {
  id          Int      @id @default(autoincrement())
  auth0UserId String
  name        String
  email       String
  topic       String
  message     String
  createdAt   DateTime @default(now())
}

// One row per completed Battle Simulation match — a running log (like
// TrainerNote/SupportRequest), never edited after creation. roundsJson holds
// the real per-round detail (which Pokémon fought which, who won each round,
// and why); teamSnapshotJson holds the trainer's FULL Dream Team roster as it
// stood at that moment (not just the Pokémon actually used in a round — the
// team can be smaller/larger than the rounds played, and changes over time,
// so this is captured separately). Both as JSON strings — one flat table is
// enough for this app's scale, no need for a normalized child table.
model BattleMatch {
  id               Int      @id @default(autoincrement())
  auth0UserId      String
  opponentName     String
  difficulty       String
  // The Bo1/Bo3/Bo5 setting picked before the match started.
  rounds           Int
  // Rounds actually played — can be less than `rounds` when a side clinches
  // the match early (e.g. a 2-0 sweep in a Best of 3 never plays round 3).
  roundsPlayed     Int
  opponentType     String
  luckFactor       String
  result           String
  yourWins         Int
  oppWins          Int
  roundsJson       String
  teamSnapshotJson String
  createdAt        DateTime @default(now())
}

// Shared reference data, not per-user — every trainer reads the same rows
// (unlike every other model here, which is scoped by auth0UserId). Seeded
// once via scripts/seed-avatar-icons.js, not written to at request time.
model AvatarIcon {
  id        Int    @id @default(autoincrement())
  // Real Pokédex id for creature icons. The 5 "General" item icons (Poké
  // Ball etc.) aren't Pokémon at all, so they get negative sentinel ids
  // (-1..-5) instead — keeps TrainerProfile.avatarPokemonId (already a
  // plain Int, already just storing whichever id the client picked) usable
  // with zero schema changes to that table.
  pokemonId Int    @unique
  name      String
  category  String
  spriteUrl String
  sortOrder Int    @default(0)
}

model TrainerProfile {
  id              Int      @id @default(autoincrement())
  auth0UserId     String   @unique
  trainerName     String
  favoriteType    String
  experienceLevel String
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  country         String
  // Real Pokédex id of the trainer's chosen profile icon — nullable since
  // existing profiles (and the "no selection yet" state) don't have one.
  avatarPokemonId Int?
  // The trainer's custom name for their Dream Team — optional, falls back to
  // a generic "Your Dream Team" label in the UI when not set.
  teamName        String?
  // Real, server-side record of whether this trainer has finished the
  // Starter Quiz — deliberately NOT client-side storage, so it's tied to
  // the actual logged-in user (survives across devices/browsers) instead of
  // one browser's localStorage.
  hasCompletedStarterQuiz Boolean @default(false)
  // Consent/preferences, set once at onboarding and never re-demanded on
  // later edits (see routes/profile.js) — acceptedPolicyAt/policyVersion are
  // always server-set, never trusted from the client.
  acceptedPolicy       Boolean   @default(false)
  acceptedPolicyAt     DateTime?
  policyVersion        String?
  marketingEmailsOptIn Boolean   @default(false)
  // Real, server-side best streak for the "Who's That Pokémon?" quiz — tied
  // to the actual logged-in user (like hasCompletedStarterQuiz above),
  // not browser localStorage. Only ever moves up (see routes/profile.js).
  whosThatBestStreak Int @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
