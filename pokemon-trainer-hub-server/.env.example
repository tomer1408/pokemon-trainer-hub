# Copy this file to .env and fill in real values.

# SQL Server connection string (trustServerCertificate is required for the
# self-signed cert used by the local Docker container).
DATABASE_URL="sqlserver://localhost:1433;database=PokemonTrainerHub;user=SA;password=<your-password>;trustServerCertificate=true"

# From Auth0: Applications -> APIs -> your API -> Identifier
AUTH0_AUDIENCE="https://your-api-identifier"

# From Auth0: your tenant Domain, with a trailing slash
AUTH0_ISSUER_BASE_URL="https://your-tenant.us.auth0.com/"

# From a separate Auth0 Machine-to-Machine Application, authorized for the
# Auth0 Management API with ONLY the `delete:users` scope — powers real
# Auth0-identity deletion in the Delete My Account flow (see
# services/auth0Management.js). Applications -> Applications -> Create
# Application -> Machine to Machine Applications -> authorize it for the
# Auth0 Management API -> check delete:users -> copy its Client ID/Secret
# from the new app's Settings tab. Without these, Delete My Account still
# removes all of a trainer's DB data, but their Auth0 login record survives
# (see accountService.js's deliberate failure-mode handling).
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=

# Optional — restricts CORS to this exact origin (your deployed client URL,
# e.g. https://pokemon-trainer-hub.vercel.app). Leave unset for local dev,
# where it falls back to allowing any origin.
CORS_ORIGIN=

# Google AI Studio API key — powers the real LangChain + Gemini-backed AI
# Trainer Assistant (team analysis, "find by description", the global chat
# widget, AI team-name suggestions). Without this, those features fall back
# to their deterministic, non-AI generators (team names) or return a 502/503
# (everything else) — the rest of the app is unaffected.
GOOGLE_API_KEY=

# Optional — defaults to "gemini-3-flash-preview" if unset.
GOOGLE_GEMINI_MODEL=

# Optional — Sentry DSN for this server's project (sentry.io -> create a
# Node.js/Express project -> Settings -> Client Keys (DSN)). Without it,
# @sentry/node no-ops safely — errors just aren't reported anywhere.
SENTRY_DSN=
